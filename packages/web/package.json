{
  "name": "@markdown-board/web",
  "version": "0.0.0",
  "private": true,
  "description": "Vite + Svelte 5 web demo. Opens a local vault via the File System Access API.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "lint": "eslint .",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@markdown-board/core": "workspace:*",
    "@markdown-board/ui": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@testing-library/svelte": "^5.2.4",
    "@types/node": "^22.9.0",
    "happy-dom": "^15.11.6",
    "svelte": "^5.2.0",
    "svelte-check": "^4.0.9",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.4"
  }
}
