{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "types": ["node", "svelte"],
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "e2e/**/*",
    "vite.config.ts",
    "svelte.config.js",
    "playwright.config.ts"
  ]
}
