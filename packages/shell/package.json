{
  "name": "@markdown-board/shell",
  "version": "0.0.0",
  "private": true,
  "description": "Platform-agnostic vault shell: VaultApp orchestrator, modals, and vault helpers. Web and desktop inject their own file adapter, picker, and watcher.",
  "type": "module",
  "main": "./src/index.ts",
  "svelte": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@markdown-board/core": "workspace:*",
    "@markdown-board/ui": "workspace:*",
    "minisearch": "^7.1.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@testing-library/svelte": "^5.2.4",
    "@types/node": "^22.9.0",
    "happy-dom": "^15.11.6",
    "svelte": "^5.2.0",
    "svelte-check": "^4.0.9",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.4"
  }
}
