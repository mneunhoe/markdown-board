{
  "name": "@markdown-board/plugin-api",
  "version": "1.0.0",
  "private": true,
  "description": "Public types and runtime contract for markdown-board plugins.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@markdown-board/core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^5"
  },
  "devDependencies": {
    "svelte": "^5.2.0",
    "typescript": "^5.6.3"
  }
}
