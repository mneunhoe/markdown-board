{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "markdown-board",
  "version": "0.0.0",
  "identifier": "dev.markdown-board.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "markdown-board",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Productivity",
    "publisher": "markdown-board",
    "copyright": "Copyright © 2026 markdown-board contributors",
    "shortDescription": "Kanban-first knowledge workspace on plain Markdown files you own.",
    "longDescription": "markdown-board is a local-first task board and notes workspace that reads and writes plain Markdown files in a folder you own. The desktop build wraps the @markdown-board/ui front-end with a TauriFileAdapter and a native file watcher.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mneunhoe/markdown-board/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY3MkZEMTUwMTFDQzEwNjIKUldSaUVNd1JVTkV2WjljbGZjWDlGQVpFSExpTllKa0ZYTGdsZjhCSFVwK0NDV2lHVSs1MHpzNlgK"
    }
  }
}
