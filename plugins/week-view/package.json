{
  "name": "@markdown-board/plugin-week-view",
  "version": "1.0.0",
  "private": true,
  "description": "Seven-column board grouped by day-of-week.",
  "type": "module",
  "main": "./src/main.ts",
  "svelte": "./src/main.ts",
  "types": "./src/main.ts",
  "exports": {
    ".": {
      "types": "./src/main.ts",
      "svelte": "./src/main.ts",
      "default": "./src/main.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@markdown-board/core": "workspace:*",
    "@markdown-board/plugin-api": "workspace:*",
    "@markdown-board/ui": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@testing-library/svelte": "^5.2.4",
    "@types/node": "^22.9.0",
    "happy-dom": "^15.11.6",
    "svelte": "^5.2.0",
    "svelte-check": "^4.0.9",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.4"
  }
}
